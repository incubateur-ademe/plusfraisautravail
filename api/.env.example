VIGILANCE_APP_ID=your-meteo-france-application-id
CACHE_TTL_SECONDS=3600

# RTE Ecowatt (optional). Register at https://data.rte-france.com,
# create a "Web Server" application, subscribe to Ecowatt v5, then paste the credentials below.
# Leave both empty to disable the /alerts/electricity endpoint (returns 503).
RTE_CLIENT_ID=
RTE_CLIENT_SECRET=
# Set to true to hit the RTE sandbox (canned data, useful in summer when prod is all-vert).
# Sandbox still requires the OAuth credentials above.
RTE_USE_SANDBOX=false
