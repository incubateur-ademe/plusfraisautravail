vigilance_app_id = "your-meteo-france-application-id"

# RTE Ecowatt OAuth2 credentials. Leave empty to disable the
# /alerts/electricity endpoint (the API returns 503 instead of crashing).
rte_client_id     = ""
rte_client_secret = ""
rte_use_sandbox   = false

# PlusFraîcheMaVille Climadiag commune-search API. Leave the token empty to
# disable /climadiag/search (the API returns 503 instead of crashing).
# climadiag_api_url defaults to the staging host in variables.tf until PFMV
# issues a production token - only override it here if you have one.
climadiag_api_token = ""

# On first apply, leave api_deploy = false. After pushing an image to the
# registry, set api_image to the full reference and api_deploy = true.
api_image  = ""
api_deploy = false

# Django SECRET_KEY for the cms app.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
django_secret_key = ""

# Same chicken-and-egg bootstrap shape as api_image/api_deploy above.
cms_image  = ""
cms_deploy = false

# The cms container's own Scaleway domain isn't known until after it's first
# created (see DEPLOY.md 2.8) - add it here once you have it from
# `tofu output cms_url` and re-apply.
cms_extra_allowed_hosts = []

# scw_access_key / scw_secret_key are NOT set here - export them as
# TF_VAR_scw_access_key / TF_VAR_scw_secret_key instead (same value as
# SCW_ACCESS_KEY / SCW_SECRET_KEY, see DEPLOY.md 2.1). Keeping API keys out
# of tfvars files, even gitignored ones, avoids them ending up in a stray
# `tofu show`/backup/screen-share.
