DJANGO_SECRET_KEY=change-me
DEBUG=true
# JSON list, e.g. ["localhost", "127.0.0.1"]
ALLOWED_HOSTS=["localhost"]

# postgresql://user:password@host:port/dbname - or sqlite:///db.sqlite3 for local dev
DATABASE_URL=sqlite:///db.sqlite3

# S3 media storage - leave empty for local dev (media uploads will fail,
# everything else works)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=fr-par
